# Qwen3 (DashScope) API Key — 必填
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# 使用的 Qwen 模型（默认 qwen-plus，可改为 qwen-turbo / qwen-max）
QWEN_MODEL=qwen-plus

# 数据库路径（相对于 backend/ 目录）
BUSINESS_DB_PATH=database/business.db
APP_DB_PATH=database/app.db

# CORS 允许的源
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 服务端口
APP_HOST=0.0.0.0
APP_PORT=8000
